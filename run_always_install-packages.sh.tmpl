{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash
# Packages hash: {{ include ".chezmoidata/packages.yaml" | sha256sum }}

set -u

BREWFILE="$(mktemp -t brewfile.XXXXXX)"
trap 'rm -f "$BREWFILE"' EXIT

cat > "$BREWFILE" <<EOF
{{ range .packages.universal.taps -}}
tap {{ . | quote | replace " " "\", \"" }}
{{ end -}}
{{ range .packages.universal.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.universal.casks -}}
cask {{ . | quote }}
{{ end -}}
{{ range .packages.universal.mas -}}
mas {{ .name | quote }}, id: {{ .id }}
{{ end -}}
EOF

# Update Homebrew and upgrade everything
brew update
brew upgrade
brew upgrade --cask --greedy

# Install missing packages from Brewfile
brew bundle install --file="$BREWFILE"

# Remove anything installed but not in Brewfile (non-interactive)
HOMEBREW_BUNDLE_FORCE_CLEANUP=1 brew bundle cleanup --force --file="$BREWFILE"

brew cleanup && brew autoremove
{{ end -}}
